CLEVAI_API_URL=https://api.clevai.edu.vn/api/v1/so/meeting/search
CLEVAI_API_TIMEOUT=30
CLEVAI_PAGE_SIZE=50
CLEVAI_MAX_WORKERS=8
CLEVAI_BEARER_TOKEN=

